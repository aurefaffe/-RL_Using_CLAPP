def train_with_sb3_alternative(opt, env, model_path, device):
    """
    Alternative utilisant PPO avec un extracteur de caractéristiques personnalisé
    """

    class FeatureExtractorWrapper(gym.Wrapper):
        def __init__(self, env, encoder):
            super().__init__(env)
            self.encoder = encoder
            self.observation_space = gym.spaces.Box(
                low=-np.inf, high=np.inf, shape=(1024,), dtype=np.float32
            )
            
        
        def reset(self, **kwargs):
            obs, info = self.env.reset(**kwargs)
            print(obs.shape)
            return self._extract_features(obs), info
        
        def step(self, action):
            obs, reward, terminated, truncated, info = self.env.step(action)
            return self._extract_features(obs), reward, terminated, truncated, info
        
        def _extract_features(self, obs):
            obs = torch.tensor(obs, dtype=torch.float32)# Add batch dimension
            obs = obs.view(obs.shape[2], 1, obs.shape[0], obs.shape[1]) 
            with torch.no_grad():
                features = self.encoder(obs, all_layers=False)
                features = features[1]
            
            return features.numpy()
    
    # Charger l'encodeur
    encoder = load_model(model_path=model_path).eval()
    encoder.to(device)
    
    if device.type == 'mps':
        encoder.compile(backend="aot_eager")
    
    for param in encoder.parameters():
        param.requires_grad = False
    
    wrapped_env = FeatureExtractorWrapper(env, encoder)
    vec_env = DummyVecEnv([lambda: wrapped_env])  # Environnement vectorisé pour PPO
    
    
    model = PPO(
        "MlpPolicy",
        vec_env,
        learning_rate=opt.actor_lr,
        gamma=opt.gamma,
        verbose=1,
        device=device,
        tensorboard_log="./tensorboard_logs/" if opt.track_run else None,
    )
    
    
    if opt.track_run:
            mlflow.start_run(run_name= opt.run_name)
            mlflow.log_params(
            {
                'lr1': opt.actor_lr,
                'lr2': opt.critic_lr,
                'encoder': opt.encoder,
                'num_epochs': opt.num_epochs,
                
            }
        )
    model.learn(
            total_timesteps=opt.num_epochs * opt.max_episode_steps,
            progress_bar=True
        )
    
    
    
        # Entraîner
        
    
    env.close()

    
 


